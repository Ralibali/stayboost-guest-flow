# Public site configuration
VITE_PUBLIC_PLAUSIBLE_DOMAIN=stayboost.se
# Set only when all demo routes are published. Example: https://demo.stayboost.se
VITE_PUBLIC_DEMO_BASE=

# 46elks SMS demo
ELKS_API_USER=
ELKS_API_PASSWORD=
ELKS_SENDER=StayBoost

# Brevo contact capture
BREVO_API_KEY=
BREVO_PILOT_LIST_ID=
BREVO_TEMPLATES_LIST_ID=
# Backward-compatible fallback for the pilot list
BREVO_LIST_ID=

# Recommended production rate limiting (Upstash Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Use a long random value in production so phone/IP hashes cannot be precomputed
RATE_LIMIT_SALT=
