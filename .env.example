# StayBoost — miljövariabler för frontend (/app-operatörsvy och /g-gästsida)
# Skapa ett Supabase-projekt, kör supabase/migrations/20260719000000_fas1.sql,
# deploya supabase/functions/* och fyll i värdena nedan (t.ex. i .env.local).

VITE_SUPABASE_URL=https://<PROJEKT-REF>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-nyckel>

# Edge-funktionernas hemligheter (sätts i Supabase, INTE här):
# CRON_SECRET, BREVO_API_KEY, BREVO_SENDER_EMAIL, BREVO_SENDER_NAME,
# ELKS_API_USER, ELKS_API_PASSWORD, ELKS_SENDER, GUEST_PAGE_BASE_URL
#
# Stripe (kortbetalning i bokningsmotorn):
# STRIPE_SECRET_KEY        — secret key från Stripe Dashboard → Developers → API keys
# STRIPE_WEBHOOK_SECRET    — signing secret från Developers → Webhooks
#                            (endpoint: <SUPABASE_URL>/functions/v1/stripe-webhook,
#                             events: checkout.session.completed + checkout.session.expired)
# PUBLIC_APP_URL           — t.ex. https://boka.dindomän.se (används för
#                            Stripes success/cancel-länkar; annars Origin-headern)
